import qubesadmin

def get_apps():
    domains = qubesadmin.Qubes().domains
    return [qube for qube in domains
    if int(qube.features.get("dispvm-preload-max", 0)) > 0
    and qube.klass == "AppVM"
    and getattr(qube, "template_for_dispvms", False)
    ]

